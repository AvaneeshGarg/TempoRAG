digraph {
	rankdir=LR size="16,10"
	fontname=Helvetica
	node [fontname=Helvetica shape=box style="rounded,filled"]
	subgraph cluster_input {
		color="#1f4e79" fillcolor="#dbe9f4" fontname="Helvetica-Bold" label="CLINICAL INPUT (Frontend)" style="rounded,filled"
		clinical_query [label="Clinical Query Input" fillcolor=white]
		risk_param [label="Risk Parameter Input" fillcolor=white]
	}
	api [label="API GATEWAY" color="#2a6f97" fillcolor="#a9d6e5" style="rounded,filled"]
	subgraph cluster_rag {
		color="#3a5a40" fillcolor="#e9f5ec" label="AGENTIC RAG PIPELINE (LangGraph)" style="rounded,filled"
		retrieve [label="1. RETRIEVE NODE
SapBERT + FAISS" fillcolor="#cfe2ff"]
		rerank [label="2. RERANK NODE
Decay: ETVD, Sigmoid, BioScore" fillcolor="#cfe2ff"]
		generate [label="3. GENERATE NODE
Tool-Augmented LLM" fillcolor="#cfe2ff"]
	}
	subgraph cluster_tools {
		color="#6c757d" fillcolor="#f1f3f5" label="CLINICAL TOOL LAYER (LangChain)" style="rounded,filled"
		pubmed [label=search_pubmed fillcolor="#ffffff"]
		predict [label="predict_heart_failure_risk
(ChronosModel)" fillcolor="#ffffff"]
	}
	subgraph cluster_eval {
		color="#7f5539" fillcolor="#fff4e6" label="OFFLINE EVALUATION SUBSYSTEM" style="rounded,filled"
		benchmark [label="BENCHMARK DATASET" fillcolor=white]
		ablation [label="ABLATION RUNNER" fillcolor=white]
		metrics [label="METRICS ENGINE" fillcolor=white]
		results [label=RESULTS fillcolor=white]
	}
	summary [label="CLINICAL INSIGHT & RESULTS SUMMARY" color="#b45309" fillcolor="#fde68a" style="rounded,filled"]
	clinical_query -> api
	risk_param -> api
	api -> retrieve
	retrieve -> rerank
	rerank -> generate
	generate -> pubmed
	generate -> predict
	api -> benchmark
	benchmark -> ablation
	ablation -> metrics
	metrics -> results
	results -> summary
}
